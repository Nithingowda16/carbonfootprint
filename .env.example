# EcoTrack AI Configuration Template

# Backend Settings
FLASK_DEBUG=true
PORT=5000
HOST=0.0.0.0
SECRET_KEY=development-flask-secret-key-replace-in-production
JWT_SECRET_KEY=development-jwt-secret-key-replace-in-production

# Database Settings
# Default: sqlite local file database
DATABASE_URL=sqlite:///ecotrack.db
# PostgreSQL (Production/Docker deployment):
# DATABASE_URL=postgresql://ecotrack:ecotrackpassword@localhost:5432/ecotrack

# Frontend Settings
# Set VITE_API_URL for local development:
VITE_API_URL=http://localhost:5000/api
